# CareStream Environment Configuration
# Backend Settings
CARESTREAM_PORT=8000
SERVER_IP=192.168.1.x
SECRET_KEY=change-me-to-a-random-string

# Timezone - Set to your local timezone (default: America/New_York)
TZ=America/New_York
# Other timezone examples: America/New_York, America/Los_Angeles, UTC, Europe/London

# Database & Media
MEDIA_PATH=/carestream/media
DB_PATH=/carestream/data/carestream.db

# Android Device Settings
ADB_PORT=5555
ADB_PUSH_DEST=/sdcard/carestream/
# VIDEO_PLAYER_PACKAGE - Optional: specify video player package for device
# Leave blank or comment out to auto-detect available player on each device
# Fallback strategy tries: Viewsonic players → RockChip → VLC → Archos → MX Player → Stock
# Common packages:
#   Viewsonic: com.reveldigital.player (Revel Digital), com.iadea.player.general (iAdea)
#   RockChip: android.rk.RockVideoPlayer
#   VLC: org.videolan.vlc
# Example (force Revel Digital for Viewsonic):
# VIDEO_PLAYER_PACKAGE=com.reveldigital.player

# Service Settings
HEARTBEAT_INTERVAL=300

# Frontend Settings
# Authentication Passwords for each role
# Set unique passwords for each user type
REACT_APP_AUTH_USER_PW=password
REACT_APP_AUTH_ADMIN_PW=password
REACT_APP_AUTH_SUPERUSER_PW=password
